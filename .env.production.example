# =============================================================================
# Шаблон production env-файла. Скопировать в .env.production и заполнить.
#
#   cp .env.production.example .env.production
#
# .env.production в .gitignore — НЕ коммитить.
# =============================================================================

# ── Postgres (контейнер) ────────────────────────────────────────────────────
# Эти три переменные используются:
#   1) сервисом postgres для инициализации БД при первом запуске
#   2) сервисом backend для построения DATABASE_URL
POSTGRES_USER=pmtask
POSTGRES_PASSWORD=ЗАМЕНИ_МЕНЯ_strong_password
POSTGRES_DB=pmtask

# ── Backend host port ───────────────────────────────────────────────────────
# Порт на хосте, на который пробрасывается 5001 контейнера.
# На этапе 4 (Caddy) этот пункт уйдёт.
BACKEND_HOST_PORT=5001

# ── Backend runtime ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001
HOST=0.0.0.0
LOG_LEVEL=info

# ── JWT ─────────────────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_DAYS=30

# ── CORS ────────────────────────────────────────────────────────────────────
# Список Origin'ов через запятую. На проде — только реальный домен.
# Если на этапе 2 ещё нет домена — оставь пустым (CORS будет открыт).
CORS_ORIGINS=

# ── SMTP (Yandex для отправки OTP-писем) ────────────────────────────────────
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ── Yandex Cloud Object Storage ─────────────────────────────────────────────
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Expo Push ───────────────────────────────────────────────────────────────
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
EXPO_ACCESS_TOKEN=
