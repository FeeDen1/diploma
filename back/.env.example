# =============================================================================
# Среда выполнения
# =============================================================================
# development | production | test
NODE_ENV=development

# Хост и порт HTTP-сервера. 0.0.0.0 — слушать на всех интерфейсах
# (нужно, чтобы устройство в локальной Wi-Fi доставало бэк по IP ноута).
HOST=0.0.0.0
PORT=5001

# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# =============================================================================
# База данных (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pmtask

# =============================================================================
# JWT
# =============================================================================
# Минимум 32 символа. Сгенерировать можно через: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_DAYS=30

# =============================================================================
# CORS
# =============================================================================
# Список разрешённых Origin'ов через запятую.
# Пусто или закомментировано — CORS открыт для всех (для dev).
# Для прода: CORS_ORIGINS=https://api.pm-task.ru,https://pm-task.ru
CORS_ORIGINS=

# =============================================================================
# SMTP (для OTP-писем)
# =============================================================================
# Если MAIL_HOST не задан — приложение работает в режиме «лог в stdout»
# (полезно для dev: код OTP виден в консоли бэка, без реальной отправки).
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@pm-task.local

# =============================================================================
# S3 (Yandex Cloud Object Storage)
# =============================================================================
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=pm-task
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# Expo Push Notifications
# =============================================================================
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
# Опционально, но без токена Expo чаще режет rate-limit.
# Получить: expo whoami → expo accesstoken:create
EXPO_ACCESS_TOKEN=

# =============================================================================
# Redis (опционально для dev)
# =============================================================================
# Если REDIS_URL не задан — кеш работает in-memory внутри процесса.
# Локальный Redis: docker run --rm -p 6379:6379 redis:7-alpine
# REDIS_URL=redis://localhost:6379
