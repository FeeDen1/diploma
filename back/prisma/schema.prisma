// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"

}

enum UserRole {
  student
  adapter
  admin
}

enum UserStatus {
  pending
  active
  suspended
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole   @default(student)
  status       UserStatus @default(pending)
  firstName    String    @map("first_name") @db.VarChar(50)
  lastName     String    @map("last_name") @db.VarChar(50)
  ratingTotal  Int        @default(0) @map("rating_total")
  spentPoints  Int        @default(0) @map("spent_points")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  avatarFileId  String?  @unique @map("avatar_file_id") @db.Uuid
  avatarFile    File?    @relation("AvatarFile", fields: [avatarFileId], references: [id], onDelete: SetNull)

  refreshTokens     RefreshToken[]
  groupMemberships  GroupMember[]
  groupAdapterships GroupAdapter[]
  submissions       TaskSubmission[]
  uploadedFiles     File[]          @relation("UploadedFiles")
  emailOtps         EmailOtp[]
  deviceTokens      DeviceToken[]
  rewardOrders      RewardRedemption[]

  @@index([role, status])
  @@map("users")
}

enum DevicePlatform {
  ios
  android
}

/**
 * Expo Push Token для push-уведомлений. Один и тот же физический девайс
 * может перепривязываться к разным юзерам (если на устройстве сменили
 * аккаунт), поэтому уникальность по токену, а не по паре (token, userId).
 */
model DeviceToken {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  expoToken   String         @unique @map("expo_token") @db.VarChar(255)
  platform    DevicePlatform
  lastSeenAt  DateTime       @default(now()) @map("last_seen_at") @db.Timestamptz()
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

enum OtpPurpose {
  email_verification
  password_reset
}

model EmailOtp {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  purpose     OtpPurpose
  codeHash    String     @map("code_hash") @db.VarChar(255)
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz()
  usedAt      DateTime?  @map("used_at") @db.Timestamptz()
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, usedAt])
  @@map("email_otps")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum Direction {
  pmi
  piit
  bd
  pkt
}

model Group {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(100)
  year      Int
  direction Direction
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  members  GroupMember[]
  adapters GroupAdapter[]

  @@index([direction])
  @@map("groups")
}

model GroupMember {
  groupId  String   @map("group_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model GroupAdapter {
  groupId    String   @map("group_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_adapters")
}

enum TaskType {
  general
}

enum TaskCategory {
  study
  sport
  outdoor
  teambuilding
  activism
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  title       String       @db.VarChar(200)
  description String       @db.Text
  type        TaskType     @default(general)
  category    TaskCategory
  points      Int
  taskFileId  String?      @unique @map("task_file_id") @db.Uuid
  expiresAt   DateTime?    @map("expires_at") @db.Timestamptz()
  archivedAt  DateTime?    @map("archived_at") @db.Timestamptz()
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  taskFile    File?            @relation("TaskFile", fields: [taskFileId], references: [id], onDelete: SetNull)
  submissions TaskSubmission[]

  @@index([archivedAt])
  @@index([expiresAt])
  @@index([category])
  @@map("tasks")
}

model TaskSubmission {
  id               String           @id @default(uuid()) @db.Uuid
  taskId           String           @map("task_id") @db.Uuid
  studentId        String           @map("student_id") @db.Uuid
  status           SubmissionStatus @default(pending)
  submissionFileId String           @unique @map("submission_file_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  task           Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student        User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submissionFile File @relation("SubmissionFile", fields: [submissionFileId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@map("task_submissions")
}

enum FileType {
  avatar
  task
  submission
  reward
}

enum FileVisibility {
  public
  private
}

model File {
  id          String         @id @default(uuid()) @db.Uuid
  ownerUserId String         @map("owner_user_id") @db.Uuid
  bucket      String         @db.VarChar(100)
  objectKey   String         @map("object_key") @db.VarChar(500)
  visibility  FileVisibility @default(public)
  mimeType    String         @map("mime_type") @db.VarChar(100)
  sizeBytes   Int            @map("size_bytes")
  type        FileType
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  owner          User            @relation("UploadedFiles", fields: [ownerUserId], references: [id], onDelete: Cascade)
  avatarOf       User?           @relation("AvatarFile")
  taskFile       Task?           @relation("TaskFile")
  submissionFile TaskSubmission? @relation("SubmissionFile")
  rewardImage    RewardItem?     @relation("RewardImage")

  @@map("files")
}

model RewardItem {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(200)
  price       Int
  imageFileId String?   @unique @map("image_file_id") @db.Uuid
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  imageFile   File?               @relation("RewardImage", fields: [imageFileId], references: [id], onDelete: SetNull)
  redemptions RewardRedemption[]

  @@index([archivedAt])
  @@map("reward_items")
}

enum RedemptionStatus {
  pending
  fulfilled
  cancelled
}

/**
 * Заказ мерча. itemTitle/itemPrice — снимок на момент покупки: даже если
 * лот удалят или переименуют, в истории заказа останется корректное
 * отображение того, что и за сколько было заказано.
 */
model RewardRedemption {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  rewardItemId String?          @map("reward_item_id") @db.Uuid
  itemTitle    String           @map("item_title") @db.VarChar(200)
  itemPrice    Int              @map("item_price")
  status       RedemptionStatus @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardItem RewardItem? @relation(fields: [rewardItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("reward_redemptions")
}