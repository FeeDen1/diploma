{
  "expo": {
    "name": "PM-Task",
    "slug": "pm-task",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pmtask",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5856D6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.spbu.pmi.pmtask",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Камера используется, чтобы сделать фото-доказательство выполненного задания.",
        "NSPhotoLibraryUsageDescription": "Доступ к галерее нужен, чтобы прикрепить фото к сдаче задания.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ru.spbu.pmi.pmtask",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5856D6"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Прикрепить фото к сдаче задания.",
          "cameraPermission": "Сфотографировать выполненное задание."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#5856D6"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.spbu-pmi.ru/api",
      "router": {},
      "eas": {
        "projectId": "783a3b7c-5bf2-4627-8c8e-0935c21c319a"
      }
    },
    "owner": "denis1231",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/783a3b7c-5bf2-4627-8c8e-0935c21c319a"
    }
  }
}
